{
  "expo": {
    "name": "Calendary",
    "slug": "mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#07090F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.masterwolfix.calendary"
    },
    "android": {
      "package": "com.masterwolfix.calendary",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6366f1",
          "androidMode": "default",
          "androidCollapsedTitle": "Calendary",
          "iosDisplayInForeground": true,
          "androidStatusBarColor": "#6366f1"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "7f8a2a8b-029a-4d04-8e97-aeeb3ee6ad86"
      }
    },
    "owner": "masterwolfix"
  }
}